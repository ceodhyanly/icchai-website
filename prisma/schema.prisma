generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  institution String?
  country     String?
  role        String?
  interests   String?
  attendance         String   @default("both")
  registrationNumber String?  @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
